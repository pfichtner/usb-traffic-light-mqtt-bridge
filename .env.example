# USB Traffic Light MQTT Bridge - example configuration.
# Copy to .env and uncomment the lines you want to override.
# Defaults shown commented out; the app uses these values when left unset.

# MQTT_HOST=localhost              # MQTT broker host
# MQTT_PORT=1883                   # MQTT broker port
# MQTT_USERNAME=                   # leave empty for no auth
# MQTT_PASSWORD=                   # leave empty for no auth
# MQTT_TOPIC_PREFIX=cleware/ampel/ # topic prefix for commands (trailing / enforced)
# LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
# DEVICE_ID=default                # device id for multi-ampel setups
# LIGHT_BACKEND=auto               # auto | cleware | mock